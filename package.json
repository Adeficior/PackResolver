{
   "name": "@adeficior/pack-resolver",
   "version": "0.0.0-dev",
   "description": "Pack Resolver",
   "type": "module",
   "packageManager": "bun@1.3.14",
   "main": "./dist/index.js",
   "exports": {
      ".": "./dist/index.js",
      "./testing": "./dist/testing/index.js"
   },
   "types": "./dist/index.d.ts",
   "typesVersions": {
      "*": {
         "testing": [
            "./dist/testing/index.d.ts"
         ]
      }
   },
   "files": [
      "dist"
   ],
   "scripts": {
      "build": "tsc",
      "lint": "eslint {src,test}",
      "format": "prettier --write {src,test}",
      "test": "bun test",
      "test:ci": "bun run lint && bun run test --coverage"
   },
   "repository": {
      "type": "git",
      "url": "https://github.com/PssbleTrngle/PackResolver.git"
   },
   "publishConfig": {
      "registry": "https://npm.pkg.github.com"
   },
   "license": "ISC",
   "bugs": {
      "url": "https://github.com/PssbleTrngle/PackResolver/issues"
   },
   "homepage": "https://github.com/PssbleTrngle/PackResolver#readme",
   "devDependencies": {
      "@eslint/js": "^10.0.1",
      "@types/bun": "latest",
      "@types/minimatch": "^5.1.2",
      "eslint": "^10.5.0",
      "prettier": "^3.8.4",
      "typescript": "^5",
      "typescript-eslint": "^8.61.0"
   },
   "dependencies": {
      "minimatch": "^10.2.5",
      "zip-bun": "^1.3.8"
   }
}