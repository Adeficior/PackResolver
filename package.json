{
   "name": "@adeficior/pack-resolver",
   "version": "0.0.0-dev",
   "description": "Pack Resolver",
   "type": "module",
   "packageManager": "bun@1.3.14",
   "main": "./dist/index.js",
   "exports": {
      ".": "./dist/index.js",
      "./testing": "./dist/testing/index.js"
   },
   "types": "./dist/index.d.ts",
   "typesVersions": {
      "*": {
         "testing": [
            "./dist/testing/index.d.ts"
         ]
      }
   },
   "files": [
      "dist"
   ],
   "scripts": {
      "build": "tsc --project tsconfig.build.json",
      "check": "tsc --noEmit",
      "lint": "eslint {src,test}",
      "format": "prettier --write {src,test}",
      "test": "bun test",
      "test:ci": "bun run lint && bun run test --coverage",
      "prepare": "husky"
   },
   "repository": {
      "type": "git",
      "url": "git+https://github.com/Adeficior/PackResolver.git"
   },
   "license": "ISC",
   "bugs": {
      "url": "https://github.com/Adeficior/PackResolver/issues"
   },
   "homepage": "https://github.com/Adeficior/PackResolver#readme",
   "devDependencies": {
      "@eslint/js": "^10.0.1",
      "@types/bun": "latest",
      "@types/minimatch": "^5.1.2",
      "eslint": "^10.5.0",
      "husky": "^9.1.7",
      "prettier": "^3.8.4",
      "typescript": "^6.0.3",
      "typescript-eslint": "^8.61.0"
   },
   "dependencies": {
      "minimatch": "^10.2.5",
      "node-stream-zip": "^1.15.0",
      "zip-a-folder": "^6.1.1"
   }
}